{
  "manifest_version": 3,
  "name": "Transcriber for YouTube",
  "version": "1.6.20",
  "description": "One-click transcription for videos and podcasts. Works with transcribed.dev or your own self-hosted instance.",
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' http://localhost:19720 http://127.0.0.1:19720 https://transcribed.dev https://www.transcribed.dev; frame-src https://transcribed.dev https://www.transcribed.dev; object-src 'none'; base-uri 'none'; form-action 'none'"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "sidePanel",
    "scripting",
    "nativeMessaging"
  ],
  "optional_permissions": [
    "notifications",
    "downloads",
    "clipboardWrite",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:19720/*",
    "http://127.0.0.1:19720/*",
    "https://transcribed.dev/*",
    "https://www.transcribed.dev/*",
    "*://*.youtube.com/*",
    "*://open.spotify.com/*"
  ],
  "optional_host_permissions": [
    "*://*.vimeo.com/*",
    "*://podcasts.apple.com/*",
    "*://*.twitch.tv/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["destination-connected.html", "destination-connected.js"],
      "matches": [
        "https://www.transcribed.dev/*",
        "https://transcribed.dev/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
