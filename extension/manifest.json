{
  "manifest_version": 3,
  "name": "YouTube Transcriber",
  "version": "1.3.0",
  "description": "One-click transcription for YouTube videos and Spotify podcasts via your local transcriber service",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "sidePanel",
    "scripting"
  ],
  "optional_permissions": [
    "notifications",
    "downloads",
    "clipboardWrite",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:19720/*",
    "http://127.0.0.1:19720/*",
    "https://transcribed.dev/*",
    "https://www.transcribed.dev/*",
    "*://*.youtube.com/*",
    "*://open.spotify.com/*"
  ],
  "optional_host_permissions": [
    "*://*.vimeo.com/*",
    "*://podcasts.apple.com/*",
    "*://*.twitch.tv/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
